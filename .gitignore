# =========================
# Operating System Files
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =========================
# IDEs and Editors
# =========================
.vscode/
.idea/
*.swp
*.swo
*~
.vs/

# =========================
# Frontend (Node.js & Next.js)
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# Next.js environment variables (DO NOT COMMIT)
# If you want a template, commit a .env.example instead
frontend/.env
frontend/.env*.local

# =========================
# Backend (Python & FastAPI)
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
backend/venv/
backend/env/
backend/.venv/
backend/ENV/
backend/env.bak/
backend/venv.bak/

# Environment structure / config
backend/.env
backend/.env.local
backend/alembic.ini

# pytest / coverage
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/

# SQLite databases (if used locally)
*.sqlite3
*.db

# =========================
# Global Ignore Files
# =========================
# Secret files that should never be committed anywhere in the monorepo
.env
.env.*
!.env.example
*.log
*.bak
*.tmp
